# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# URLs — aceita várias origens separadas por vírgula (ex: produção + Vercel preview)
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
# URL pública usada nos links de imagens (/cdn) — em produção use o domínio do site (ex: https://spacepoint.shop)
API_PUBLIC_URL=https://spacepoint.shop

# For cookies to work, frontend and backend should be on the same domain
# In production, use the same domain with different subdomains or paths

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/spacepoint?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Discord OAuth ──────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# ─── SMTP / Email ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Space Point <noreply@spacepoint.com>"

# ─── Cookies ──────────────────────────────────────────────────────────────────
COOKIE_DOMAIN=localhost
COOKIE_SAME_SITE=lax
