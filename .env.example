# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# URLs — aceita várias origens separadas por vírgula (ex: produção + Vercel preview)
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
# URL pública usada nos links de imagens (/cdn) — em produção use o domínio do site (ex: https://spacepoint.shop)
API_PUBLIC_URL=https://spacepoint.shop

# For cookies to work, frontend and backend should be on the same domain
# In production, use the same domain with different subdomains or paths

# ─── Database ─────────────────────────────────────────────────────────────────
# Local (sem TLS):
DATABASE_URL="postgresql://user:password@localhost:5432/spacepoint?schema=public"

# SquareCloud Postgres — URL sem params SSL (o app injeta o certificado):
# DATABASE_URL="postgresql://squarecloud:SENHA@square-cloud-db-XXXX.squareweb.app:7029/squarecloud"
#
# Opção A (recomendada em produção): cole o PEM no env (ou em base64)
# DATABASE_SSL_CERT="-----BEGIN CERTIFICATE-----
# ...
# -----END CERTIFICATE-----
# -----BEGIN PRIVATE KEY-----
# ...
# -----END PRIVATE KEY-----"
# DATABASE_SSL_CERT_BASE64="LS0tLS1CRUdJTi..."
#
# Opção B: arquivo no disco (ex.: certificate.pem na raiz do zip / src/certs/)
# DATABASE_SSL_CERT_PATH="./certificate.pem"
#
# Opção C (Prisma CLI preferido): PKCS#12
# openssl pkcs12 -export -out client.p12 -inkey certificate.pem -in certificate.pem -passout pass:squarecloud
# DATABASE_SSL_P12_PATH="./client.p12"
# DATABASE_SSL_P12_PASSWORD="squarecloud"
#
# DATABASE_SSL_MODE=verify-ca

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Discord OAuth ──────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# ─── SMTP / Email (transacionais + OTP) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Space Point <noreply@spacepoint.com>"

# ─── Cookies ──────────────────────────────────────────────────────────────────
COOKIE_DOMAIN=localhost
COOKIE_SAME_SITE=lax

# Token único para TODOS os webhooks (Efí, PagBank, Stripe, Mercado Pago)
# Cadastre na URL do provedor: ?token=SEU_TOKEN
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SHARED_SECRET=change-me-to-a-long-random-string

# Opcional: criptografa certificado Efí (.p12) no banco
# GATEWAY_ENCRYPTION_KEY=chave-longa-aleatoria
