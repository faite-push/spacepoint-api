generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id
  name         String?
  email        String?       @unique
  image        String?
  provider     String
  discordId    String?       @unique
  googleId     String?       @unique
  roleId       String?
  balance      Int           @default(0)
  passwordHash String?
  mfaSecret    String?
  mfaEnabled   Boolean       @default(false)
  isAdmin      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  couponUsages CouponUsage[]
  orders       Order[]
  payments     Payment[]
  role         Role?         @relation(fields: [roleId], references: [id])
  assignedChats Chat[]       @relation("ChatAssignee")

  @@index([roleId])
}

model Category {
  id              String     @id
  name            String
  slug            String     @unique
  parentId        String?
  imageUrl        String?
  bannerUrl       String?
  showInNavbar    Boolean    @default(false)
  showInFooter    Boolean    @default(false)
  sortOrder       Int        @default(0)
  isActive        Boolean    @default(true)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  parent          Category?  @relation("CategorySubcategories", fields: [parentId], references: [id])
  subcategories   Category[] @relation("CategorySubcategories")
  products        Product[]

  @@index([parentId])
  @@index([slug])
  @@index([showInNavbar, isActive])
  @@index([showInFooter, isActive])
}

model Product {
  id                       String           @id
  slug                     String           @unique
  name                     String
  description              Json?
  price                    Decimal          @db.Decimal(10, 2)
  comparePrice             Decimal?         @db.Decimal(10, 2)
  imageUrl                 String?
  gallery                  String[]
  images                   String[]
  stockQuantity            Int              @default(0)
  minPurchaseQuantity      Int              @default(1)
  maxPurchaseQuantity      Int?
  onePurchasePerUser       Boolean          @default(false)
  isVisible                Boolean          @default(true)
  isActive                 Boolean          @default(true)
  featured                 Boolean          @default(false)
  sortOrder                Int              @default(0)
  metaTitle                String?
  metaDescription          String?
  categoryId               String?
  deliveryType             DeliveryType     @default(automatic_lines)
  digitalLines             String[]
  digitalFileUrl           String?
  manualDeliveryNote       String?
  postPurchaseInstructions Json?
  platform                 String?
  isDigital                Boolean          @default(true)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  orderItems               OrderItem[]
  category                 Category?        @relation(fields: [categoryId], references: [id])
  codes                    ProductCode[]
  variants                 ProductVariant[]
  showcaseSections         HomeShowcaseSectionProduct[]

  @@index([slug])
  @@index([categoryId])
  @@index([isVisible, isActive])
  @@index([featured])
}

model ProductVariant {
  id                       String        @id
  productId                String
  sku                      String?
  name                     String
  description              Json?
  price                    Decimal       @db.Decimal(10, 2)
  comparePrice             Decimal?      @db.Decimal(10, 2)
  imageUrl                 String?
  gallery                  String[]
  stockQuantity            Int           @default(0)
  minPurchaseQuantity      Int           @default(1)
  maxPurchaseQuantity      Int?
  onePurchasePerUser       Boolean       @default(false)
  isVisible                Boolean       @default(true)
  isActive                 Boolean       @default(true)
  sortOrder                Int           @default(0)
  deliveryType             DeliveryType  @default(automatic_lines)
  digitalLines             String[]
  digitalFileUrl           String?
  manualDeliveryNote       String?
  postPurchaseInstructions Json?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  orderItems               OrderItem[]
  codes                    ProductCode[]
  product                  Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@index([sku])
}

model ProductCode {
  id          String          @id @default(cuid())
  productId   String
  variantId   String?
  code        String          @unique
  status      String          @default("AVAILABLE")
  deliveredAt DateTime?
  orderItemId String?
  createdAt   DateTime        @default(now())
  orderItem   OrderItem?      @relation(fields: [orderItemId], references: [id])
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId, status])
  @@index([variantId, status])
}

model Order {
  id               String       @id
  userId           String
  status           String       @default("PENDING")
  total            Int
  idempotencyKey   String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  paidAt           DateTime?
  adminNotes       String?
  discount         Int          @default(0)
  paymentExpiresAt DateTime?
  subtotal         Int          @default(0)
  paymentMethod    String?
  couponCode       String?
  checkoutData     Json?
  deliveryOption   String?      @default("standard")
  deliveryFee      Int          @default(0)
  clientIp         String?
  userAgent        String?
  chat             Chat?
  couponUsage      CouponUsage?
  user             User         @relation(fields: [userId], references: [id])
  items            OrderItem[]
  payments         Payment[]

  @@index([userId, createdAt])
  @@index([status])
}

model OrderItem {
  id            String          @id @default(cuid())
  orderId       String
  productId     String
  variantId     String?
  variantName   String?
  quantity      Int
  unitPrice     Int
  stockReserved Int             @default(0)
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product         @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  codes         ProductCode[]

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model SiteConfig {
  id                          String   @id @default("default")
  bannerImageUrl              String?
  bannerTitle                 String?
  bannerSubtitle              String?
  bannerCtaLabel              String?
  bannerCtaHref               String?
  footerText                  String?
  metaDescription             String?
  metaTitle                   String?
  storeName                   String?
  faviconUrl                  String?
  logoUrl                     String?
  contactEmail                String?
  contactPhone                String?
  primaryColor                String?
  footerAboutText             String?
  footerAboutTitle            String?
  footerCopyright             String?
  footerNewsletterEnabled     Boolean  @default(true)
  footerNewsletterPlaceholder String?
  footerNewsletterButtonLabel String?
  footerLogoUrl               String?
  footerLogoHref              String?
  footerLogoAlt               String?
  footerBackgroundColor       String?
  footerButtonTextColor       String?
  footerShowNoise             Boolean  @default(true)
  footerPaddingTopHome        Int      @default(192)
  footerPaddingTopDefault     Int      @default(48)
  footerCategoryColumnTitle   String?
  footerSupportColumnTitle    String?
  socialFacebook              String?
  socialInstagram             String?
  socialTwitter               String?
  socialLinkedin              String?
  socialYoutube               String?
  socialLinks                 Json?
  footerCategoryLinks         Json?
  footerSupportLinks          Json?
  footerLegalLinks            Json?
  topBarEnabled               Boolean  @default(false)
  topBarText                  String?
  topBarLinkUrl               String?
  topBarBackgroundColor       String?
  topBarTextColor             String?
  topBarDismissible           Boolean  @default(true)
  maintenanceModeEnabled      Boolean  @default(false)
  maintenanceTitle            String?
  maintenanceMessage          String?
  maintenanceImageUrl         String?
  page404Title                String?
  page404Message              String?
  page404ButtonLabel          String?
  page404ButtonHref           String?
  homeReviewsEnabled          Boolean  @default(true)
  homeReviewsBadgeLabel       String?
  homeReviewsTitle            String?
  homeReviewsAverageRating    Float?
  homeReviewsTotalCount       Int?
  homeReviewsGoogleMapsUrl    String?
  homeReviewsLinkLabel        String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  homeShowcaseEnabled         Boolean  @default(false)
  homeShowcaseSubtitle        String?
  homeShowcaseTitle           String?
  popupCtaLabel               String?
  popupCtaLink                String?
  popupDelay                  Int      @default(5)
  popupDescription            String?
  popupEnabled                Boolean  @default(false)
  popupImageUrl               String?
  popupTitle                  String?
  popupTrigger                String?  @default("entry")
  checkoutSettings            Json?
  chatPreChatEnabled          Boolean  @default(false)
  chatPreChatQuestions        String?
  chatWelcomeMessage          String?
  chatAutomatedMessages       String?
  pluginsConfig               Json?
  reviewsSettings             Json?
}

model InstitutionalPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  content         Json?
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isPublished, sortOrder])
}

model PageSeo {
  pageKey         String   @id
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?
  updatedAt       DateTime @updatedAt
}

model HomeReview {
  id          String   @id @default(cuid())
  name        String
  avatarUrl   String?
  rating      Int      @default(5)
  comment     String
  dateLabel   String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, sortOrder])
}

model HomeShowcaseSection {
  id        String                       @id @default(cuid())
  title     String
  subtitle  String?
  enabled   Boolean                      @default(true)
  sortOrder Int                          @default(0)
  maxItems  Int                          @default(12)
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt
  products  HomeShowcaseSectionProduct[]

  @@index([enabled, sortOrder])
}

model HomeShowcaseSectionProduct {
  id        String              @id @default(cuid())
  sectionId String
  productId String
  sortOrder Int                 @default(0)
  section   HomeShowcaseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([sectionId, productId])
  @@index([sectionId, sortOrder])
  @@index([productId])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String?
  orderId     String?
  amount      Int
  status      String
  provider    String?
  externalId  String?  @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  metadata    Json?
  order       Order?   @relation(fields: [orderId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([status])
  @@index([orderId])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([code])
  @@index([expiresAt])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  isProtected Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  sortOrder   Int          @default(0)
  users       User[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  category  String
  createdAt DateTime @default(now())
  roles     Role[]   @relation("PermissionToRole")

  @@index([key])
  @@index([category])
}

model Banner {
  id        String   @id @default(cuid())
  imageUrl  String
  linkUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Coupon {
  id              String            @id @default(cuid())
  code            String            @unique
  description     String?
  type            String            @default("PERCENTAGE")
  value           Decimal           @db.Decimal(10, 2)
  minOrderValue   Decimal?          @db.Decimal(10, 2)
  maxOrderValue   Decimal?          @db.Decimal(10, 2)
  maxDiscount     Decimal?          @db.Decimal(10, 2)
  maxUses         Int?
  usedCount       Int               @default(0)
  perUserLimit    Int?              @default(1)
  isActive        Boolean           @default(true)
  startDate       DateTime          @default(now())
  endDate         DateTime?
  allowedPayments String[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  references      CouponReference[]
  usages          CouponUsage[]

  @@index([code])
  @@index([isActive, startDate, endDate])
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  orderId   String   @unique
  discount  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([couponId])
  @@index([userId])
}

model CouponReference {
  id          String @id @default(cuid())
  couponId    String
  type        String
  referenceId String
  coupon      Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([type, referenceId])
}

model GatewayConfig {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  config    Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Chat {
  id                   String        @id @default(cuid())
  orderId              String        @unique
  status               String        @default("OPEN")
  isArchived           Boolean       @default(false)
  isResolved           Boolean       @default(false)
  rating               Int?
  ratingComment        String?
  ratingTags           Json?
  isAnonymousRating    Boolean       @default(false)
  reviewStatus         String?
  sellerResponse       String?
  assignedToId         String?
  firstAdminResponseAt DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  lastAdminReadAt      DateTime?
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignedTo           User?         @relation("ChatAssignee", fields: [assignedToId], references: [id])
  messages             ChatMessage[]
  labels               ChatLabel[]   @relation("ChatToLabel")
}

model ChatMessage {
  id         String   @id @default(cuid())
  chatId     String
  senderId   String
  senderName       String?
  senderRole       String?
  senderStaffTitle String?
  content    String
  type       String   @default("TEXT")
  fileUrl    String?
  isPinned   Boolean  @default(false)
  createdAt  DateTime @default(now())
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model ChatLabel {
  id         String               @id @default(cuid())
  name       String               @unique
  color      String               @default("#3b82f6")
  chats      Chat[]               @relation("ChatToLabel")
  references ChatLabelReference[]
}

model ChatLabelReference {
  id          String    @id @default(cuid())
  labelId     String
  type        String
  referenceId String
  label       ChatLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@index([labelId])
  @@index([type, referenceId])
}

model ChatMacro {
  id        String   @id @default(cuid())
  shortcut  String   @unique
  content   String
  category  String   @default("geral")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DeliveryType {
  automatic_lines
  file
  manual_chat
  mixed
  manual
  automatic_text
}
